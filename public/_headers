/*
  Security headers for all routes
*/
/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com https://fonts.googleapis.com; img-src 'self' https://images.unsplash.com data: blob:; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'
  X-Robots-Tag: noindex

/*
  Fingerprinted Vite assets - aggressive caching
*/
/assets/*
  Cache-Control: public, max-age=31556952, immutable

/*
  Static assets - long cache
*/
/*.svg
  Cache-Control: public, max-age=31556952, immutable
/*.png
  Cache-Control: public, max-age=31556952, immutable
/*.jpg
  Cache-Control: public, max-age=31556952, immutable
/*.woff2
  Cache-Control: public, max-age=31556952, immutable

/*
  Production domain - indexable, no rewrite
*/
https://titanbuild.co/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com https://fonts.googleapis.com; img-src 'self' https://images.unsplash.com data: blob:; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'
